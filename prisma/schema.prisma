generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  // Can review records (approve/return) and see the dashboard/reports, but
  // cannot manage workers, customers, teams, projects or settings.
  SUPERVISOR
  WORKER
}

// Which app a position belongs to: the office app (ADMIN) or the field app
// (WORKER). This is the hard app gate; granular capabilities live in
// Position.permissions (see src/lib/permissions.ts).
enum AccessLevel {
  ADMIN
  WORKER
}

// A per-company job position. Companies define their own (Supervisor,
// Accountant, Dispatcher, Foreman…), each granting a set of capability keys
// from the fixed catalog. `role` on User still gates which app you enter; a
// Position refines what you can do inside it.
model Position {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  description    String?
  color          String?
  accessLevel    AccessLevel  @default(WORKER)
  // Capability keys from src/lib/permissions.ts (PermissionKey[]).
  permissions    String[]     @default([])
  // Built-in positions seeded to mirror the ADMIN/SUPERVISOR/WORKER roles; they
  // can be edited but not deleted, so a company keeps a valid fallback.
  isSystem       Boolean      @default(false)
  // Stable key for the built-in positions ("admin" / "supervisor" / "worker"),
  // null for company-created ones. Lets us localize their name and map them to
  // the legacy role. Unique per org (one of each).
  systemKey      String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  members        User[]       @relation("UserPosition")

  @@unique([organizationId, name])
  @@unique([organizationId, systemKey])
  @@index([organizationId])
}

// A tenant. Every company using the app is one Organization; all
// company-scoped data (users, customers, records, and - later - projects,
// photos, teams) carries an organizationId so one company can never see
// another's data. organizationId is nullable for now to land the column
// safely on the live single-tenant data; it is backfilled to the default
// org in the same migration and becomes required in a later slice.
model Organization {
  id        String       @id @default(cuid())
  name      String
  slug      String       @unique
  // Rotatable invite code: a person signs in with Google and enters this
  // to join the company as a WORKER. Admins can regenerate it from Settings.
  // Nullable so an org can have joining-by-code turned off.
  joinCode  String?      @unique
  // Company-wide settings (admin-editable in Settings). All optional so
  // existing orgs keep working; the app falls back to its old behaviour when
  // a value is unset.
  defaultLeadPay   Decimal? @db.Decimal(10, 2)
  defaultHelperPay Decimal? @db.Decimal(10, 2)
  // Monthly paid-revenue target shown as a goal thermometer on Financials.
  // Null = no goal set.
  monthlyRevenueGoal Decimal? @db.Decimal(12, 2)
  // Currency symbol shown before money amounts (defaults to "$").
  currencySymbol   String   @default("$")
  // Platform-level on/off switch, toggled only from the super-admin console.
  // True = normal. False = suspended (enforcement wired in a follow-up).
  active           Boolean  @default(true)
  suspendedAt      DateTime?
  // Platform "watch": the owner flags a company to keep an eye on (churn risk,
  // onboarding follow-up, VIP). Purely a console signal — invisible to the
  // tenant. Null watchedAt = not watched; watchNote is the optional reason.
  watchedAt        DateTime?
  watchNote        String?
  watchedBy        String?
  // Per-company module toggles (feature flags), managed from the super-admin
  // console. Default on so every existing org keeps all modules.
  featureInvoicing Boolean  @default(true)
  featureEstimates Boolean  @default(true)
  featurePortal    Boolean  @default(true)
  // Subscription plan. Null = legacy/grandfathered (no plan limits); set to a
  // real plan when assigned from the console or via Stripe checkout.
  plan             Plan?
  // Stripe billing linkage (Fase B). Null until the company starts a checkout.
  stripeCustomerId     String?   @unique
  stripeSubscriptionId String?
  // Raw Stripe subscription status: active, trialing, past_due, canceled, …
  subscriptionStatus   String?
  currentPeriodEnd     DateTime?
  // Stripe Connect linkage for online invoice payments: the company connects
  // its own Standard account and customers pay invoices directly into it.
  // Null until the company starts onboarding; chargesEnabled flips true once
  // Stripe confirms the account can accept charges.
  stripeConnectAccountId     String?  @unique
  stripeConnectChargesEnabled Boolean @default(false)
  // When true, a work record can't be submitted without at least one photo.
  requirePhoto     Boolean  @default(false)
  // When true, a work record requires a helper name to be submitted.
  requireHelper    Boolean  @default(false)
  // When true (the default, matching prior behaviour), a work record requires
  // the customer's signature; turn off for unattended jobs.
  requireCustomerSignature Boolean @default(true)
  // When true, an approved record is locked for everyone (admins included);
  // it must be reopened (set back to needs-changes) before it can be edited.
  lockApprovedRecords Boolean @default(false)
  // Extra company details printed on the work-record PDF header.
  companyPhone     String?
  companyAddress   String?
  licenseNumber    String?
  // Company logo (Vercel Blob URL) shown on the work-record PDF header.
  logoUrl          String?
  // Optional default text pre-filled into a new record's "work performed"
  // notes, so a crew can start from a standard template.
  defaultWorkNotes String?  @db.Text
  // Scheduler: a day is flagged "overloaded" for a worker when they have this
  // many jobs (or more) that day. Admin-configurable in Settings.
  scheduleOverloadThreshold Int @default(4)
  // Default sales-tax rate (percent, e.g. 8.25) pre-filled on new invoices.
  // Null = no default; each invoice can still set its own rate.
  defaultTaxRate   Decimal? @db.Decimal(5, 2)
  // --- Notifications: company-wide switches the notify helpers honour before
  // sending. Default on, matching prior always-send behaviour. ---
  notifyOnSubmit   Boolean  @default(true)
  notifyOnReview   Boolean  @default(true)
  notifyReminders  Boolean  @default(true)
  // Reply-to address for outbound emails (blank = provider default).
  notifyReplyTo    String?
  // --- Scheduling defaults ---
  // Pre-filled length of a new scheduled job, in minutes.
  defaultJobDurationMinutes Int @default(120)
  // How many hours before a job its reminder should go out.
  reminderLeadHours Int @default(24)
  // First day of the week on the calendar: 0 = Sunday, 1 = Monday.
  weekStartsOn     Int @default(1)
  // --- Numbering & documents ---
  // Optional prefix shown before the suggested next job number (e.g. "WO-").
  jobNumberPrefix  String?
  // Footer line printed on the work-record PDF / receipt.
  pdfFooter        String?  @db.Text
  // Default number of days a shared receipt link stays valid. Null = never.
  receiptExpiryDays Int?
  // Unguessable token for the public, read-only financial report at
  // /share/[token]. Null = sharing off; set when an admin turns it on.
  reportToken      String?  @unique
  // Reimbursement rate per mile for the worker mileage log. Null = show miles
  // only (no money estimate).
  mileageRate      Decimal? @db.Decimal(6, 2)
  // --- Localization ---
  // Clock format for times shown across the app: "12" or "24".
  timeFormat       String   @default("12")
  // IANA time zone (e.g. "America/New_York") used to turn a job's wall-clock
  // start into a real instant for reminders. "UTC" keeps the prior behaviour.
  timeZone         String   @default("UTC")
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  users     User[]
  customers Customer[]
  records   WorkRecord[]
  projects  Project[]
  photos    Photo[]
  teams     Team[]
  tags      Tag[]
  comments  Comment[]
  checklistTemplates ChecklistTemplate[]
  checklists         Checklist[]
  workTypeCategories WorkTypeCategory[]
  workTypes          WorkType[]
  scheduledJobs      ScheduledJob[]
  orgSkills          OrgSkill[]
  reviewEvents       RecordReviewEvent[]
  roleChangeEvents   RoleChangeEvent[]
  invoices           Invoice[]
  auditEvents        AuditEvent[]
  estimates          Estimate[]
  supportSessions    ImpersonationSession[]
  notes              OrgNote[]
  platformMessages   PlatformMessage[]
  reminders          OrgReminder[]
  positions          Position[]
  timeOff            TimeOff[]
  notifications      Notification[]
  expenses           Expense[]
  expenseCategories  ExpenseCategory[]
  expenseRules       ExpenseRule[]
  materials          Material[]
  mileageEntries     MileageEntry[]
}

// A worker's mileage log entry: miles driven on a day, optionally noted. Feeds
// a personal running total (and a reimbursement estimate when the org sets a
// per-mile rate).
model MileageEntry {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  date           DateTime     @db.Date
  miles          Decimal      @db.Decimal(8, 2)
  note           String?      @db.Text
  createdAt      DateTime     @default(now())

  @@index([organizationId])
  @@index([userId, date])
}

// An org-managed catalog of materials with a unit + unit cost, attached to a
// work record (with a snapshot) to build the material side of job costing.
model Material {
  id             String           @id @default(cuid())
  organizationId String
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  // Free-text unit label (ft, box, each…); optional.
  unit           String?
  unitCost       Decimal          @db.Decimal(10, 2)
  createdAt      DateTime         @default(now())
  recordMaterials RecordMaterial[]

  @@unique([organizationId, name])
  @@index([organizationId])
}

// A material line on a work record. Name + unit cost are snapshotted so a line
// survives the catalog item being renamed or deleted.
model RecordMaterial {
  id         String     @id @default(cuid())
  recordId   String
  record     WorkRecord @relation(fields: [recordId], references: [id], onDelete: Cascade)
  materialId String?
  material   Material?  @relation(fields: [materialId], references: [id], onDelete: SetNull)
  name       String
  quantity   Decimal    @db.Decimal(10, 2)
  unitCost   Decimal    @db.Decimal(10, 2)
  createdAt  DateTime   @default(now())

  @@index([recordId])
  @@index([materialId])
}

// An org-managed list of expense categories (Fuel, Permits, Subcontractor…),
// mirroring how work-type categories work. Optional on an expense.
model ExpenseCategory {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  position       Int          @default(0)
  // Optional monthly spend budget for this category; null = no budget set.
  // Drives the budgets page's progress bars and over/near-budget alerts.
  monthlyBudget  Decimal?     @db.Decimal(10, 2)
  expenses       Expense[]
  rules          ExpenseRule[]
  createdAt      DateTime     @default(now())

  @@unique([organizationId, name])
  @@index([organizationId])
}

// An auto-categorization rule: when a new expense's vendor contains `keyword`
// and no category was chosen, it's filed under `category`. Org-managed.
model ExpenseRule {
  id             String          @id @default(cuid())
  organizationId String
  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  keyword        String
  categoryId     String
  category       ExpenseCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  createdAt      DateTime        @default(now())

  @@index([organizationId])
  @@index([categoryId])
}

// A business cost booked against a job or project — the other half of job
// costing (records already carry the crew's pay). Optional links so an expense
// can be general, tied to a project, or to a specific work record.
model Expense {
  id             String           @id @default(cuid())
  organizationId String
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  projectId      String?
  project        Project?         @relation(fields: [projectId], references: [id], onDelete: SetNull)
  workRecordId   String?
  workRecord     WorkRecord?      @relation(fields: [workRecordId], references: [id], onDelete: SetNull)
  categoryId     String?
  category       ExpenseCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  vendor         String
  amount         Decimal          @db.Decimal(10, 2)
  date           DateTime
  note           String?          @db.Text
  // Optional receipt image (Vercel Blob URL).
  receiptUrl     String?          @db.Text
  // Who logged it (denormalized id; name resolved on read). Nullable so a
  // deleted account keeps the expense.
  createdById    String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@index([organizationId, date])
  @@index([projectId])
  @@index([workRecordId])
}

enum SupportMode {
  FULL
  READ_ONLY
}

enum Plan {
  FREE
  PRO
}

// A platform-wide announcement banner shown to every company's admins. Only
// the most recent active one is displayed; set/cleared from the super-admin
// console. Global (no organizationId).
model Announcement {
  id        String   @id @default(cuid())
  message   String   @db.Text
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  @@index([active, createdAt])
}

// A record of a platform owner entering "support mode" for a company. Persisted
// (not just a cookie) so support sessions can expire server-side, be listed
// while active, force-ended, and shown to the company's own admins.
model ImpersonationSession {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  // The platform owner's email (from the allowlist), denormalized for display.
  actorEmail     String
  // Set when "viewing as" a specific user: the session adopts that user's exact
  // identity/permissions. Null = whole-company support (owner acts as admin).
  targetUserId   String?
  mode           SupportMode  @default(FULL)
  startedAt      DateTime     @default(now())
  expiresAt      DateTime
  endedAt        DateTime?

  @@index([organizationId])
  @@index([endedAt, expiresAt])
}

// The org's official skill catalog. Admin-curated so skill names stay
// consistent (one "HVAC", not "hvac"/"A/C"); it feeds the autocomplete on the
// profile skill input and the job's required-skill field. Workers still store
// their own skills as free UserSkill rows - this is the suggestion source.
model OrgSkill {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  createdAt      DateTime     @default(now())

  @@unique([organizationId, name])
  @@index([organizationId])
}

// A predefined "type of work" taxonomy, org-managed so the app fits any
// trade, not just HVAC. Two levels: a Category (e.g. "Installation") holds
// WorkTypes (e.g. "Furnace install"). The chosen value is still saved as the
// record's plain typeOfWork string, so records/reports/PDF are unchanged.
model WorkTypeCategory {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  position       Int          @default(0)
  workTypes      WorkType[]
  createdAt      DateTime     @default(now())

  @@unique([organizationId, name])
  @@index([organizationId])
}

model WorkType {
  id             String            @id @default(cuid())
  organizationId String
  organization   Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  categoryId     String
  category       WorkTypeCategory  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  name           String
  position       Int               @default(0)
  createdAt      DateTime          @default(now())

  @@unique([categoryId, name])
  @@index([organizationId])
  @@index([categoryId])
}

// A crew within a company. Members are Users (many-to-many via
// TeamMembership); a team can be assigned to projects. Org-scoped.
model Team {
  id             String           @id @default(cuid())
  organizationId String
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  color          String?
  memberships    TeamMembership[]
  projects       Project[]
  scheduledJobs  ScheduledJob[]
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@index([organizationId])
}

model TeamMembership {
  teamId String
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([teamId, userId])
  @@index([userId])
}

enum RecordStatus {
  SUBMITTED
  APPROVED
  NEEDS_CHANGES
}

// One entry in a work record's review history: who did what, when, and (for a
// return) the note explaining why. Denormalizes the actor's name so the
// timeline still reads correctly after an account is deleted.
enum ReviewAction {
  SUBMITTED
  APPROVED
  RETURNED
  RESUBMITTED
}

model RecordReviewEvent {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  recordId       String
  record         WorkRecord   @relation(fields: [recordId], references: [id], onDelete: Cascade)
  action         ReviewAction
  note           String?      @db.Text
  // Who performed the action. Nullable + SetNull so deleting the account keeps
  // the history; actorName preserves the display name regardless.
  actorId        String?
  actor          User?        @relation("ReviewActor", fields: [actorId], references: [id], onDelete: SetNull)
  actorName      String
  createdAt      DateTime     @default(now())

  @@index([recordId, createdAt])
  @@index([organizationId])
}

enum ProjectStatus {
  ACTIVE
  ON_HOLD
  COMPLETED
}

enum ScheduledJobStatus {
  SCHEDULED
  // The worker has acknowledged/kicked off the job from their side (accepted
  // the assignment) before physically heading out. Sits between SCHEDULED and
  // EN_ROUTE.
  STARTED
  // The crew is heading to the jobsite (live "on the way" status the customer
  // and the office can see). Sits between STARTED and IN_PROGRESS.
  EN_ROUTE
  IN_PROGRESS
  DONE
  CANCELED
}

// A jobsite (CompanyCam-style): the container work records and - later -
// photos hang off. Has an address geocoded to lat/lng so it can be pinned on
// a map. Always scoped to one Organization.
model Project {
  id             String        @id @default(cuid())
  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  address        String?
  latitude       Float?
  longitude      Float?
  status         ProjectStatus @default(ACTIVE)
  customerId     String?
  customer       Customer?     @relation(fields: [customerId], references: [id], onDelete: SetNull)
  teamId         String?
  team           Team?         @relation(fields: [teamId], references: [id], onDelete: SetNull)
  records        WorkRecord[]
  scheduledJobs  ScheduledJob[]
  invoices       Invoice[]
  estimates      Estimate[]
  expenses       Expense[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([organizationId])
  @@index([customerId])
  @@index([teamId])
  photos     Photo[]
  checklists Checklist[]
  pins       PinnedProject[]
}

// A user's pinned project, surfaced as a quick-access "Pinned" strip on their
// home. Per-user; unique so a project is pinned at most once.
model PinnedProject {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, projectId])
  @@index([userId])
}

// A jobsite photo stored in object storage (Vercel Blob). Always belongs to a
// Project; optionally also tied to a specific work record. Captures GPS +
// who/when so it reads like a CompanyCam photo feed. Org-scoped.
model Photo {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  projectId      String
  project        Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  workRecordId   String?
  workRecord     WorkRecord?  @relation(fields: [workRecordId], references: [id], onDelete: SetNull)
  url            String       @db.Text
  latitude       Float?
  longitude      Float?
  takenAt        DateTime     @default(now())
  takenById      String?
  takenBy        User?        @relation("PhotoTakenBy", fields: [takenById], references: [id], onDelete: SetNull)
  photoTags      PhotoTag[]
  comments       Comment[]
  checklistItems ChecklistItem[]
  createdAt      DateTime     @default(now())

  @@index([organizationId])
  @@index([projectId])
  @@index([workRecordId])
}

// A label applied to photos, to organize and search them. Unique per org.
model Tag {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  photoTags      PhotoTag[]
  createdAt      DateTime     @default(now())

  @@unique([organizationId, name])
  @@index([organizationId])
}

model PhotoTag {
  photoId String
  photo   Photo  @relation(fields: [photoId], references: [id], onDelete: Cascade)
  tagId   String
  tag     Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([photoId, tagId])
  @@index([tagId])
}

// A reusable checklist template (e.g. "Furnace install", "Standard service").
// Applied to a project to spawn a working Checklist with its own item states.
// Org-scoped.
model ChecklistTemplate {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  items          ChecklistTemplateItem[]
  createdAt      DateTime     @default(now())

  @@index([organizationId])
}

model ChecklistTemplateItem {
  id         String            @id @default(cuid())
  templateId String
  template   ChecklistTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  text       String
  position   Int

  @@index([templateId])
}

// A working checklist attached to a project. Its items get checked off as the
// crew works; an item can carry a photo as proof. Org-scoped.
model Checklist {
  id             String          @id @default(cuid())
  organizationId String
  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  projectId      String
  project        Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name           String
  items          ChecklistItem[]
  createdAt      DateTime        @default(now())

  @@index([organizationId])
  @@index([projectId])
}

model ChecklistItem {
  id          String    @id @default(cuid())
  checklistId String
  checklist   Checklist @relation(fields: [checklistId], references: [id], onDelete: Cascade)
  text        String
  position    Int
  done        Boolean   @default(false)
  doneAt      DateTime?
  // Optional photo attached as proof the item was completed.
  photoId     String?
  photo       Photo?    @relation(fields: [photoId], references: [id], onDelete: SetNull)
  createdAt   DateTime  @default(now())

  @@index([checklistId])
  @@index([photoId])
}

// A comment on a photo (jobsite collaboration).
model Comment {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  photoId        String
  photo          Photo        @relation(fields: [photoId], references: [id], onDelete: Cascade)
  authorId       String?
  author         User?        @relation("CommentAuthor", fields: [authorId], references: [id], onDelete: SetNull)
  body           String       @db.Text
  createdAt      DateTime     @default(now())

  @@index([organizationId])
  @@index([photoId])
}

// An audit entry recording a worker's role change: who changed it, for whom,
// from what to what, and when. Names are denormalized so the log survives an
// account deletion. Admin-visible under Settings.
model RoleChangeEvent {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  targetId       String?
  target         User?        @relation("RoleChangeTarget", fields: [targetId], references: [id], onDelete: SetNull)
  targetName     String
  actorId        String?
  actor          User?        @relation("RoleChangeActor", fields: [actorId], references: [id], onDelete: SetNull)
  actorName      String
  fromRole       Role
  toRole         Role
  createdAt      DateTime     @default(now())

  @@index([organizationId, createdAt])
}

model User {
  id               String        @id @default(cuid())
  email            String        @unique
  name             String
  phone            String?
  avatarUrl        String?
  storedSignature  String?       @db.Text
  payRate          Decimal?      @db.Decimal(10, 2)
  role             Role          @default(WORKER)
  active           Boolean       @default(true)
  // Per-worker override for the scheduler overload alert. Null falls back to
  // the organization's scheduleOverloadThreshold.
  scheduleOverloadThreshold Int?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  submittedRecords WorkRecord[]  @relation("SubmittedBy")
  approvedRecords  WorkRecord[]  @relation("ApprovedBy")
  photosTaken      Photo[]       @relation("PhotoTakenBy")
  comments         Comment[]     @relation("CommentAuthor")
  teamMemberships  TeamMembership[]
  skills           UserSkill[]
  assignedJobs     ScheduledJob[] @relation("AssignedJobs")
  createdJobs      ScheduledJob[] @relation("CreatedJobs")
  timeOff          TimeOff[]      @relation("UserTimeOff")
  timeOffCreated   TimeOff[]      @relation("TimeOffCreatedBy")
  timeOffReviewed  TimeOff[]      @relation("TimeOffReviewedBy")
  notifications    Notification[] @relation("NotificationRecipient")
  reviewEvents     RecordReviewEvent[] @relation("ReviewActor")
  roleChangesMade  RoleChangeEvent[]   @relation("RoleChangeActor")
  roleChangesGot   RoleChangeEvent[]   @relation("RoleChangeTarget")
  createdInvoices  Invoice[]           @relation("InvoiceCreatedBy")
  auditEvents      AuditEvent[]        @relation("AuditActor")
  createdEstimates Estimate[]          @relation("EstimateCreatedBy")
  mileageEntries   MileageEntry[]
  pinnedProjects   PinnedProject[]
  // Optional per-company position (job title + permissions). Falls back to the
  // legacy `role` defaults when unset. SetNull so deleting a position doesn't
  // remove its members.
  positionId       String?
  position         Position?     @relation("UserPosition", fields: [positionId], references: [id], onDelete: SetNull)
  organizationId   String?
  organization     Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([positionId])
}

model UserSkill {
  id             String       @id @default(cuid())
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  name           String
  createdAt      DateTime     @default(now())

  @@unique([userId, name])
  @@index([userId])
}

model WorkPhoto {
  id        String     @id @default(cuid())
  recordId  String
  record    WorkRecord @relation(fields: [recordId], references: [id], onDelete: Cascade)
  position  Int
  dataUrl   String     @db.Text
  createdAt DateTime   @default(now())

  @@index([recordId])
}

model Customer {
  id             String        @id @default(cuid())
  name           String
  address        String
  phone          String?
  email          String?
  // Unguessable token for the private customer portal (/portal/[token]),
  // where a customer sees their own work history, photos and invoices with
  // no login. Null = no portal link; set when an admin shares it, cleared
  // when they revoke it.
  portalToken    String?       @unique
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  records        WorkRecord[]
  projects       Project[]
  scheduledJobs  ScheduledJob[]
  invoices       Invoice[]
  estimates      Estimate[]
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // Uniqueness is enforced by a raw functional index in the migration:
  // UNIQUE (lower(name), lower(address))
  @@index([name])
  @@index([organizationId])
}

// A short-lived, single-use code minted by /native-handoff and redeemed by
// the native app's exchange call. Keeps the actual session token out of the
// eivsolutionair:// deep link, where it could be intercepted by another app
// registering the same custom scheme or linger in system/browser logs.
model NativeHandoffCode {
  id         String   @id
  token      String   @db.Text
  cookieName String
  expiresAt  DateTime
  createdAt  DateTime @default(now())

  @@index([expiresAt])
}

model WorkRecord {
  id                 String   @id @default(cuid())
  // Unguessable token for the public customer receipt. Null = not shared;
  // set when an admin shares the receipt, cleared when they stop sharing.
  publicToken        String?  @unique
  // Optional expiry for the public receipt link. Null = never expires; when
  // set and in the past, the /receipt/[token] page treats the link as gone.
  publicTokenExpiresAt DateTime?
  date               DateTime @db.Date
  jobNumber          String
  leadInstallerName  String
  helperName         String?
  customerName       String
  customerAddress    String
  arrivalTime        String
  departureTime      String
  typeOfWork         String
  workPerformedNotes String   @db.Text
  leadInstallerPay   Decimal  @db.Decimal(10, 2)
  helperPay          Decimal? @db.Decimal(10, 2)
  // Manual revenue for the job's profitability card, used when the job isn't
  // invoiced (cash work). Ignored when a non-void invoice exists — that
  // invoice's subtotal is the revenue instead. Null = unset.
  jobValue           Decimal? @db.Decimal(10, 2)
  customerSignature  String       @db.Text
  installerSignature String       @db.Text
  status             RecordStatus @default(SUBMITTED)
  reviewNote         String?      @db.Text
  // Customer satisfaction, captured from the public receipt (1-5 stars +
  // optional comment). Null until the customer rates the visit.
  customerRating     Int?
  customerFeedback   String?      @db.Text
  customerRatedAt    DateTime?
  // The office's public-facing reply to the customer's feedback.
  feedbackResponse   String?      @db.Text
  feedbackRespondedAt DateTime?
  approvedAt         DateTime?
  approvedById       String?
  approvedBy         User?        @relation("ApprovedBy", fields: [approvedById], references: [id], onDelete: SetNull)
  customerId         String?
  customer           Customer?    @relation(fields: [customerId], references: [id], onDelete: SetNull)
  photos             WorkPhoto[]
  // Nullable + SetNull so an admin can delete a worker's account without
  // losing their records (the record keeps its denormalized installer
  // names; only the "who entered it" link is cleared), mirroring how
  // deleting a Customer detaches its records.
  submittedById      String?
  submittedBy        User?        @relation("SubmittedBy", fields: [submittedById], references: [id], onDelete: SetNull)
  organizationId     String?
  organization       Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  projectId          String?
  project            Project?     @relation(fields: [projectId], references: [id], onDelete: SetNull)
  projectPhotos      Photo[]
  scheduledJob       ScheduledJob?
  reviewEvents       RecordReviewEvent[]
  invoices           Invoice[]
  expenses           Expense[]
  recordMaterials    RecordMaterial[]
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  @@index([date])
  @@index([jobNumber])
  @@index([customerName])
  @@index([organizationId])
  @@index([projectId])
  // Covers status-only lookups (e.g. pending-review counts) via the
  // leftmost column, plus the status+date range scans the pay report and
  // dashboard run - replaces the old standalone @@index([status]).
  @@index([status, date])
}

// A planned visit on the calendar: who goes where, on what day, to do what.
// This is the *before-the-fact* plan, independent of WorkRecord (the
// after-the-fact record the crew fills out on site). When the crew finishes,
// the job can be linked to the work record it produced (workRecordId). A job
// can be assigned to a single worker and/or a whole team. Org-scoped.
model ScheduledJob {
  id             String             @id @default(cuid())
  organizationId String
  organization   Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  title          String
  notes          String?            @db.Text
  // The calendar day the job is planned for (date-only, like WorkRecord.date).
  scheduledFor   DateTime           @db.Date
  // Optional wall-clock window as "HH:MM" strings, matching how WorkRecord
  // stores arrival/departure - keeps the crew's local time exactly as entered.
  startTime      String?
  endTime        String?
  // Optional skill the job needs, so the scheduler can flag when the assigned
  // worker doesn't have it. Free text, matched against UserSkill names.
  requiredSkill  String?
  status         ScheduledJobStatus @default(SCHEDULED)
  // Who's going. A job can target one worker, a team, or both.
  assignedToId   String?
  assignedTo     User?              @relation("AssignedJobs", fields: [assignedToId], references: [id], onDelete: SetNull)
  teamId         String?
  team           Team?              @relation(fields: [teamId], references: [id], onDelete: SetNull)
  // What/where. Optional links to a saved customer and/or project so the
  // worker can jump to the jobsite and pre-fill a record.
  customerId     String?
  customer       Customer?          @relation(fields: [customerId], references: [id], onDelete: SetNull)
  projectId      String?
  project        Project?           @relation(fields: [projectId], references: [id], onDelete: SetNull)
  // The work record this job produced once the crew filed it (one-to-one).
  workRecordId   String?            @unique
  workRecord     WorkRecord?        @relation(fields: [workRecordId], references: [id], onDelete: SetNull)
  // Groups the occurrences created together as a recurring series (weekly /
  // biweekly / monthly). Null for one-off jobs. Each occurrence is otherwise a
  // fully independent job (its own status, edits, linked record).
  seriesId       String?
  createdById    String?
  createdBy      User?              @relation("CreatedJobs", fields: [createdById], references: [id], onDelete: SetNull)
  statusEvents   JobStatusEvent[]
  // When the pre-job reminder was sent (Settings → Scheduling lead time), so the
  // hourly reminder pass sends each timed job's reminder at most once. Null until
  // reminded.
  reminderSentAt DateTime?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  @@index([organizationId, scheduledFor])
  @@index([assignedToId])
  @@index([teamId])
  @@index([customerId])
  @@index([projectId])
  @@index([seriesId])
}

// Append-only trail of a scheduled job's live status changes, so the office
// and the customer can see the timeline: scheduled → on the way → working →
// done, with who moved it and when.
model JobStatusEvent {
  id        String             @id @default(cuid())
  jobId     String
  job       ScheduledJob       @relation(fields: [jobId], references: [id], onDelete: Cascade)
  status    ScheduledJobStatus
  // Denormalized actor name so the trail survives a worker's account deletion.
  actorId   String?
  actorName String
  createdAt DateTime           @default(now())

  @@index([jobId, createdAt])
}

// A worker's day (or run of days) off — vacation, sick, personal. The scheduler
// reads these to warn the office before booking someone who's away, and to show
// "off" on the calendar. Date-only, inclusive on both ends. Org-scoped.
// Time off is either entered by the office (status APPROVED straight away) or
// requested by the worker from their profile (status PENDING until an office
// user approves/denies it). Only APPROVED entries mark someone unavailable on
// the schedule.
enum TimeOffStatus {
  PENDING
  APPROVED
  DENIED
}

model TimeOff {
  id             String        @id @default(cuid())
  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String
  user           User          @relation("UserTimeOff", fields: [userId], references: [id], onDelete: Cascade)
  // Inclusive date range (a single day = start == end).
  startDate      DateTime      @db.Date
  endDate        DateTime      @db.Date
  reason         String?
  // APPROVED by default so existing office-entered rows keep marking people off.
  status         TimeOffStatus @default(APPROVED)
  reviewedById   String?
  reviewedBy     User?         @relation("TimeOffReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)
  reviewedAt     DateTime?
  // The office's note when denying (or adjusting) a request; shown to the worker.
  reviewNote     String?
  createdById    String?
  createdBy      User?         @relation("TimeOffCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt      DateTime      @default(now())

  @@index([organizationId, startDate])
  @@index([organizationId, status])
  @@index([userId])
}

// Which tab of the in-app bell a notification lands in.
//  PERSONAL - something that happened to the recipient's own work.
//  COMPANY  - operational activity the office should act on.
//  SYSTEM   - account / billing / platform notices.
enum NotificationCategory {
  PERSONAL
  COMPANY
  SYSTEM
}

// A persisted in-app notification for one recipient, written alongside every
// email the app sends so the same message also shows in the header bell. Each
// row keeps the actor (who caused it) and enough denormalized detail to render
// a self-contained card without another lookup. Org-scoped; read state is
// per-recipient (readAt). Cascade-deleted with the recipient or the org.
model Notification {
  id             String               @id @default(cuid())
  organizationId String
  organization   Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  // The recipient.
  userId         String
  user           User                 @relation("NotificationRecipient", fields: [userId], references: [id], onDelete: Cascade)
  category       NotificationCategory
  // A stable key for the kind of event (e.g. "record_approved"), so the UI can
  // pick an icon/tone. Free-form string, not an enum, to stay open to new types.
  type           String
  title          String
  body           String?
  // Who caused it, denormalized so the card survives the actor's deletion.
  actorId        String?
  actorName      String?
  // Optional in-app deep link the card opens.
  href           String?
  // Null until the recipient opens their bell; set when marked read.
  readAt         DateTime?
  createdAt      DateTime             @default(now())

  @@index([userId, createdAt])
  @@index([userId, readAt])
  @@index([organizationId])
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  VOID
}

// A customer invoice: line items (labour, materials, etc.) plus a tax rate,
// with subtotal/tax/total computed from the items. Financial record, so the
// customer name/address are snapshotted and survive customer edits/deletes.
model Invoice {
  id              String        @id @default(cuid())
  // Sequential per organization, shown as "INV-0001". Uniqueness enforced by
  // the composite constraint below; allocation is max()+1 at create time.
  number          Int
  organizationId  String
  organization    Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customerId      String?
  customer        Customer?     @relation(fields: [customerId], references: [id], onDelete: SetNull)
  projectId       String?
  project         Project?      @relation(fields: [projectId], references: [id], onDelete: SetNull)
  // Optional source work record when the invoice was generated from one, so
  // the record can show it's been billed and we avoid double-invoicing.
  workRecordId    String?
  workRecord      WorkRecord?   @relation(fields: [workRecordId], references: [id], onDelete: SetNull)
  status          InvoiceStatus @default(DRAFT)
  issueDate       DateTime      @db.Date
  dueDate         DateTime?     @db.Date
  // Percent, e.g. 8.25. Stored per invoice so historical rates stay correct.
  taxRate         Decimal       @default(0) @db.Decimal(5, 2)
  notes           String?       @db.Text
  // Snapshot of who's billed, independent of the live Customer row.
  customerName    String
  customerAddress String?
  // Unguessable token for the public customer view (null = not shared).
  publicToken     String?       @unique
  paidAt          DateTime?
  createdById     String?
  createdBy       User?         @relation("InvoiceCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  lineItems       InvoiceLineItem[]
  // Set when this invoice was generated by converting an accepted estimate.
  fromEstimate    Estimate?     @relation("EstimateInvoice")
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@unique([organizationId, number])
  @@index([organizationId])
  @@index([status])
  @@index([customerId])
  @@index([projectId])
  @@index([workRecordId])
}

model InvoiceLineItem {
  id          String   @id @default(cuid())
  invoiceId   String
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  description String
  quantity    Decimal  @default(1) @db.Decimal(10, 2)
  unitPrice   Decimal  @default(0) @db.Decimal(10, 2)
  position    Int      @default(0)
  createdAt   DateTime @default(now())

  @@index([invoiceId])
}

// A generic, append-only audit trail of admin mutations (customers,
// projects, invoices, settings…). Complements the record review and role
// change logs with a single "who changed what, when" timeline. actorName is
// denormalized so the entry survives account deletion.
model AuditEvent {
  id             String        @id @default(cuid())
  // Null for platform-level events (e.g. granting a platform admin) that don't
  // belong to any one company; set for every company-scoped event.
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  actorId        String?
  actor          User?        @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)
  actorName      String
  // Machine key like "invoice.void" or "customer.delete".
  action         String
  // The kind of thing changed: "customer" | "project" | "invoice" | "settings".
  entityType     String
  entityId       String?
  // Human-readable one-liner shown in the log.
  summary        String
  // True when performed by a platform owner (super-admin) rather than a
  // company user — lets the platform console filter its own actions.
  isPlatform     Boolean      @default(false)
  createdAt      DateTime     @default(now())

  @@index([organizationId, createdAt])
  @@index([isPlatform, createdAt])
}

enum EstimateStatus {
  DRAFT
  SENT
  ACCEPTED
  DECLINED
}

// A quote/estimate sent to a customer before the work. Mirrors Invoice, plus
// an accept/decline lifecycle and a one-way link to the invoice it becomes
// once accepted and converted (so it's never converted twice).
model Estimate {
  id              String         @id @default(cuid())
  number          Int
  organizationId  String
  organization    Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customerId      String?
  customer        Customer?      @relation(fields: [customerId], references: [id], onDelete: SetNull)
  projectId       String?
  project         Project?       @relation(fields: [projectId], references: [id], onDelete: SetNull)
  status          EstimateStatus @default(DRAFT)
  issueDate       DateTime       @db.Date
  expiryDate      DateTime?      @db.Date
  taxRate         Decimal        @default(0) @db.Decimal(5, 2)
  notes           String?        @db.Text
  customerName    String
  customerAddress String?
  publicToken     String?        @unique
  acceptedAt      DateTime?
  // The invoice this estimate was converted into (one-to-one), if any.
  convertedInvoiceId String?     @unique
  convertedInvoice   Invoice?    @relation("EstimateInvoice", fields: [convertedInvoiceId], references: [id], onDelete: SetNull)
  createdById     String?
  createdBy       User?          @relation("EstimateCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  lineItems       EstimateLineItem[]
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@unique([organizationId, number])
  @@index([organizationId])
  @@index([status])
  @@index([customerId])
  @@index([projectId])
}

model EstimateLineItem {
  id          String   @id @default(cuid())
  estimateId  String
  estimate    Estimate @relation(fields: [estimateId], references: [id], onDelete: Cascade)
  description String
  quantity    Decimal  @default(1) @db.Decimal(10, 2)
  unitPrice   Decimal  @default(0) @db.Decimal(10, 2)
  position    Int      @default(0)
  createdAt   DateTime @default(now())

  @@index([estimateId])
}

// Platform admins granted from the /super console, in addition to the
// SUPER_ADMIN_EMAILS environment allowlist. Env owners are the trust root and
// the only ones who can add/remove rows here; a DB-granted admin gets console
// access but cannot manage this list. `email` is stored normalized (the same
// normalization used for duplicate detection) so lookups match sign-in emails.
model PlatformAdmin {
  id        String   @id @default(cuid())
  email     String   @unique
  invitedBy String?
  createdAt DateTime @default(now())
}

// A private, platform-only note pinned to a company, written by the owner/admins
// from the /super console. Never visible to the company itself — it's an
// internal memo (context, follow-ups, "watch this account"). Kept as a separate
// model so it's cleanly walled off from tenant data and cascades on org delete.
model OrgNote {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  // Author's platform email, denormalized for display (like ImpersonationSession).
  authorEmail    String
  body           String       @db.Text
  createdAt      DateTime     @default(now())

  @@index([organizationId, createdAt])
}

// A dated follow-up the platform sets on a company ("check in on onboarding by
// Friday"). Console-only; surfaces on the platform Home when due/overdue until
// marked done. Separate model so a company can carry several open follow-ups.
model OrgReminder {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy      String
  note           String       @db.Text
  dueAt          DateTime
  doneAt         DateTime?
  createdAt      DateTime     @default(now())

  @@index([doneAt, dueAt])
  @@index([organizationId, dueAt])
}

// A record of a targeted in-app message the platform sent to a company. The
// message is also fanned out as per-recipient notifications; this row is the
// single "sent" entry that powers the history on the company page.
model PlatformMessage {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  senderEmail    String
  title          String
  body           String       @db.Text
  // "admins" | "all" — who it was addressed to.
  audience       String
  recipientCount Int
  createdAt      DateTime     @default(now())

  @@index([organizationId, createdAt])
}
