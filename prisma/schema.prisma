generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  WORKER
}

enum RecordStatus {
  SUBMITTED
  APPROVED
}

model User {
  id               String       @id @default(cuid())
  email            String       @unique
  name             String
  role             Role         @default(WORKER)
  active           Boolean      @default(true)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  submittedRecords WorkRecord[] @relation("SubmittedBy")
}

model WorkPhoto {
  id        String     @id @default(cuid())
  recordId  String
  record    WorkRecord @relation(fields: [recordId], references: [id], onDelete: Cascade)
  position  Int
  dataUrl   String     @db.Text
  createdAt DateTime   @default(now())

  @@index([recordId])
}

model Customer {
  id        String       @id @default(cuid())
  name      String
  address   String
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  records   WorkRecord[]

  // Uniqueness is enforced by a raw functional index in the migration:
  // UNIQUE (lower(name), lower(address))
  @@index([name])
}

model WorkRecord {
  id                 String   @id @default(cuid())
  date               DateTime @db.Date
  jobNumber          String
  leadInstallerName  String
  helperName         String?
  customerName       String
  customerAddress    String
  arrivalTime        String
  departureTime      String
  typeOfWork         String
  workPerformedNotes String   @db.Text
  leadInstallerPay   Decimal  @db.Decimal(10, 2)
  helperPay          Decimal? @db.Decimal(10, 2)
  customerSignature  String       @db.Text
  installerSignature String       @db.Text
  status             RecordStatus @default(SUBMITTED)
  customerId         String?
  customer           Customer?    @relation(fields: [customerId], references: [id], onDelete: SetNull)
  photos             WorkPhoto[]
  submittedById      String
  submittedBy        User         @relation("SubmittedBy", fields: [submittedById], references: [id])
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  @@index([date])
  @@index([jobNumber])
  @@index([customerName])
  @@index([status])
}
