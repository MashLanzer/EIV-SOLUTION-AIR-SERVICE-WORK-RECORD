DATABASE_URL="postgresql://user:password@host:5432/dbname?schema=public"
AUTH_SECRET="generate-with: openssl rand -base64 32"
NEXTAUTH_URL="http://localhost:3000"

# Only needed temporarily in production to bootstrap the first admin account
# via GET /api/setup?key=... (see src/app/api/setup/route.ts). Remove the env
# var and the route once the first admin account has been created.
SETUP_SECRET="generate-with: openssl rand -hex 24"
